OPENAI_API_KEY=sk-...
POSTGRES_PASSWORD=your-secure-password
OPEN_BRAIN_API_KEY=your-random-api-key
NODE_ENV=production

# VM SSH configuration (for shell/OpenClaw tools)
# Container auto-generates SSH keypair on first start — check GET /health for public key
VM_SSH_HOST=your-vm-ip
VM_SSH_USER=your-ssh-user
VM_SSH_PORT=22
